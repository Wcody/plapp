// ======================================
// 🔥 核心：UTS 标准类型定义（全平台兼容）
// ======================================
export type FlagItem = {
  freq: number;
  time: number;
};

export type ProgramItem = {
  title: string;
  features: string[];
  desc: string;
  no: number;
  best: string[];
  totalFreqs: string;
  totalTime: number;
  flags: FlagItem[];
  hasDamos: boolean;
};

// 定义映射类型：key 是标题(string)，value 是程序对象(ProgramItem)
export type ProgramsMap = Map<string, ProgramItem>;

// 定义映射类型：key 是序号(number)，value 是程序对象(ProgramItem)
export type ProgramsNoMap = Map<number, ProgramItem>;


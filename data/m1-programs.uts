// ======================================
// 修复：用 UTS 原生对象做映射（抛弃UTSJSONObject，零报错）
// ======================================
export const getProgramsMap = (): ProgramsMap => {
	// 1. 创建空映射对象（标准UTS对象，无任何原生兼容问题）
	const map: ProgramsMap = new Map<string, ProgramItem>();
	// 2. 遍历赋值（类型完全安全）
	programsList.forEach((program: ProgramItem) => {
		map.set(program.title, program)
	});
	// 3. 返回映射表
	return map;
};

// ======================================
// 修复：用 UTS 原生对象做映射（抛弃UTSJSONObject，零报错）
// ======================================
export const getProgramsNoMap = (): ProgramsNoMap => {
	// 1. 创建空映射对象（标准UTS对象，无任何原生兼容问题）
	const map: ProgramsNoMap = new Map<number, ProgramItem>();
	// 2. 遍历赋值（类型完全安全）
	programsList.forEach((program: ProgramItem) => {
		map.set(program.no, program)
	});
	// 3. 返回映射表
	return map;
};

// 定义启动前需要存储的数据类型，完成后再重新赋值到对应位置
export type StartBeforeItem = {
	intensity: number;
	frequency: number;
	timeMinutes: number;
	timeMax: number;
	timeMin: number;
	timeStep: number;
	timeUnit: string;
	intervalHandle: number;
}

// 手动定义「可选版本」的类型，替代 Partial<StartBeforeItem>
export type StartBeforeItemOptional = {
	intensity?: number;
	frequency?: number;
	timeMinutes?: number;
	timeMax?: number;
	timeMin?: number;
	timeStep?: number;
	timeUnit?: string;
	intervalHandle?: number;
}

/**
 * 根据传入参数初始化数据
 * 传入的字段 → 覆盖
 * 没传入的 → 使用默认缺省值
 */
export function intiStartBeforeItem(
	data: StartBeforeItemOptional | null = null
): StartBeforeItem {
	// 默认缺省值
	const defaults: StartBeforeItem = {
		intensity: 100,
		frequency: 10,
		timeMinutes: 10,
		timeMax: 60,
		timeMin: 5,
		timeStep: 5,
		timeUnit: 'Min',
		intervalHandle: 0,
	};
	
	if (data == null || (
		data.intensity == null
			&& data.frequency == null
			&& data.timeMinutes == null
			&& data.timeMax == null
			&& data.timeMin == null
			&& data.timeStep == null
			&& data.timeUnit == null
			&& data.intervalHandle == null
	)) {
		return defaults;
	} else {
		// 合并：传入的覆盖默认值
		return {
			...defaults,
			...data,
		};
	}
}
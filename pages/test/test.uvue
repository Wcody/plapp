<template>
	<scroll-view class="page" scroll-y>
		<view class="container">
			<!-- 操作按钮 -->
			<view class="btn-group">
				<button class="btn btn-gap" @click="startScan">1. 扫描设备</button>
				<button class="btn btn-gap" :class="deviceId.length == 0 ? 'btn-disabled' : ''"
					:disabled="deviceId.length == 0" @click="connectDevice">2. 连接设备</button>
				<button class="btn btn-gap" :class="!isConnected ? 'btn-disabled' : ''" :disabled="!isConnected"
					@click="disconnectDevice">3. 断开连接</button>
				<button class="btn" :class="!isConnected ? 'btn-disabled' : ''" :disabled="!isConnected"
					@click="readDeviceInfo">4. 查询从机信息1</button>
				<button class="btn btn-gap" :class="!isConnected ? 'btn-disabled' : ''" :disabled="!isConnected"
					@click="sendTestData">5. 下发参数2</button>
				<button class="btn btn-gap" :class="!isConnected ? 'btn-disabled' : ''" :disabled="!isConnected"
					@click="readDeviceParam">6. 查询从机参数3</button>
			</view>

			<!-- 状态展示 -->
			<view class="info-card">
				<text class="card-title">蓝牙状态</text>
				<text class="text">蓝牙适配器：{{ bleEnabled ? '✅ 已开启' : '❌ 未开启' }}</text>
				<text class="text">扫描状态：{{ scanning ? '🔍 扫描中...' : '停止扫描' }}</text>
				<text class="text">设备ID：{{ deviceId.length > 0 ? deviceId : '未获取' }}</text>
				<text class="text">连接状态：{{ isConnected ? '✅ 已连接' : '❌ 未连接' }}</text>
			</view>

			<!-- 数据日志 -->
			<view class="log-card">
				<text class="card-title">接收数据日志</text>
				<text class="log-content">{{ logText }}</text>
			</view>
		</view>
	</scroll-view>
</template>

<script lang="uts" setup>
import { onMounted, onUnmounted } from "vue";
import { useBluetooth } from '@/utils/useBluetooth.uts';

// =============== 这个页面自己的设备ID，改这里就行 ===============
const CURRENT_DEVICE_ID = "B4:C2:E0:E7:C4:34";
const bluetooth = useBluetooth(CURRENT_DEVICE_ID);
const bleEnabled = bluetooth.bleEnabled;
const scanning = bluetooth.scanning;
const deviceId = bluetooth.deviceId;
const isConnected = bluetooth.isConnected;
const logText = bluetooth.logText;

function startScan() {
	bluetooth.startScan();
}

function connectDevice() {
	bluetooth.connectDevice();
}

function disconnectDevice() {
	bluetooth.disconnectDevice();
}

function readDeviceInfo() {
	bluetooth.readDeviceInfo();
}

function sendTestData() {
	bluetooth.sendTestData();
}

function readDeviceParam() {
	bluetooth.readDeviceParam();
}

bluetooth.initBluetoothListener();
bluetooth.initAutoFlow();

onMounted(() => {
	
});

onUnmounted(() => {
	bluetooth.destroyBluetooth();
});
</script>

<style scoped>
	.page {
		flex: 1;
		background-color: #f5f5f5;
	}

	.container {
		padding: 20rpx;
	}

	.btn-group {
		display: flex;
		flex-direction: column;
		margin-bottom: 24rpx;
	}

	.btn-gap {
		margin-bottom: 16rpx;
	}

	.btn {
		height: 88rpx;
		background-color: #007aff;
		color: white;
		border-radius: 12rpx;
		font-size: 32rpx;
	}

	.btn-disabled {
		background-color: #ccc;
		color: #999;
	}

	.info-card,
	.log-card {
		background: white;
		border-radius: 16rpx;
		padding: 24rpx;
		margin-bottom: 24rpx;
	}

	.card-title {
		font-size: 36rpx;
		font-weight: bold;
		margin-bottom: 16rpx;
		color: #333;
	}

	.text {
		font-size: 28rpx;
		color: #666;
		line-height: 1.6;
	}

	.log-content {
		font-size: 24rpx;
		color: #444;
		line-height: 1.5;
		white-space: pre-wrap;
		max-height: 600rpx;
	}
</style>

<template>
	<view class="container">
		<!-- 右上角喇叭声音开关 -->
		<view class="sound-switch" @click="toggleSound">
			<text v-if="globalData.playSound" class="sound-icon">🔊</text>
			<text v-else class="sound-icon">🔇</text>
		</view>

		<image class="logo" src="/static/1024x1024.png"></image>
		<text class="title">{{ title }}</text>
		<text class="version">{{ version }}</text>

		<view v-show="false" class="custom-box">
			<button class="custom-btn" @click="customSelect(1)">PL-M1</button>
			<button class="custom-btn" @click="customSelect(2)">PL-DUO-USER</button>
			<button class="custom-btn" @click="customSelect(3)">PL-DUO-PRO</button>
			<button class="custom-btn" @click="showLog()">ShowLog</button>
		</view>
		<!-- 底部居中扫一扫按钮 -->
		<view class="scan-box">
			<view class="scan-btn" @click="scanCode">
				<text class="scan-btn-text">Scan QR Code</text>
			</view>
		</view>
	</view>
</template>

<script setup lang="uts">
	import { ref } from 'vue';
	import { formatUpperMac } from '@/utils/common.uts';
	import { globalData, setCurrentClinic, setCurrentDeviceId } from '@/utils/object.uts';

	const title = ref('Welcome to EQ FLUX!')
	const version = ref('v2.0.5')

	// 声音开关切换
	const toggleSound = () => {
		globalData.playSound = !globalData.playSound;
		// 可选提示
		// uni.showToast({
		// 	title: globalData.playSound ? 'Sound ON' : 'Sound OFF',
		// 	icon: 'none'
		// })
	}

	const openWinByOperId = (operId : number) => {
		let url : string = '/pages/index/index'
		// UTS 推荐使用 === 严格相等，避免类型装箱警告
		if (operId == 1) {
			url = '/pages/m1/m1';
		} else if (operId == 2) {
			url = '/pages/duo/user'
		} else if (operId == 3) {
			url = '/pages/duo/duo'
		}
		uni.navigateTo({
			url: url,
			success(result) {
				console.log('navigateTo success', result.errMsg)
			},
			fail(error) {
				console.log('navigateTo fail', error.errMsg)
			},
			complete(result) {
				console.log('navigateTo complete', result.errMsg)
			},
		})
	}

	// 扫一扫
	const scanCode = () => {
		uni.scanCode({
			success: (res) => {
				console.log('result:', res.result)

				// ✅ 1. 空值安全判断
				if (res.result == '' || res.result.length < 1) {
					uni.showToast({ title: 'QR code content is empty', icon: 'error' })
					return
				}

				// ✅ 2. 分割并自动去空格
				const items = res.result.split(';').map(item => item.trim())
				console.log('items:', items)

				// ✅ 3. 正确判断长度（3个字段就判断 ===3）
				if (items.length == 4 || items.length == 5) {
					// ✅ 4. 正确解构
					const [type, ui, mac, emp] = items
					console.log('type:', type, 'ui:', ui, 'mac:', mac, 'emp', emp)

					const macs = mac.split(':').map(item => item.trim());
					console.log('macs:', macs);

					if (macs.length == 2) {
						setCurrentDeviceId(formatUpperMac(macs[1]));
						console.log('formatted deviceId:', globalData.deviceId);
					} else {
						uni.showToast({ title: 'Invalid MAC format', icon: 'error' });
						return;
					}

					// ✅ 5. 大小写不敏感判断
					if (!type.includes('BLE')) {
						uni.showToast({ title: 'Invalid QR code type', icon: 'error' })
						return
					}

					// ✅ 6. 设备类型判断
					if (ui.includes('M1')) {
						openWinByOperId(1)
					} else if (emp.includes('NULL')) {
						setCurrentClinic(0);
						openWinByOperId(2)
					} else if (emp.includes('CLINIC')) {
						setCurrentClinic(1);
						openWinByOperId(3)
					} else {
						uni.showToast({ title: 'Unknown device type', icon: 'error' })
					}
				} else {
					uni.showToast({ title: 'Invalid QR code format', icon: 'none' })
				}
			},
			fail: () => {
				uni.showToast({ title: 'Scan failed', icon: 'none' })
			}
		})
	}

	const customSelect = (operId : number) => {
		openWinByOperId(operId)
	}

	const showLog = () => {
		uni.navigateTo({
			url: '/pages/log/logM1',
			success(result) {
				console.log('navigateTo success', result.errMsg)
			},
			fail(error) {
				console.log('navigateTo fail', error.errMsg)
			},
			complete(result) {
				console.log('navigateTo complete', result.errMsg)
			},
		})
	}
</script>

<style>
	/* 主容器：黑色主题 + 居中布局 */
	.container {
		flex: 1;
		display: flex;
		flex-direction: column;
		align-items: center; /* 这里改成 center，横向居中所有子元素 */
		justify-content: flex-start;
		padding: 0 30px;
		box-sizing: border-box;
		background-color: #000;
		position: relative;
	}
	
	/* 右上角声音开关 */
	.sound-switch {
		position: absolute;
		top: 20px; /* 往下挪一点，避免贴顶太难看 */
		right: 30px;
		z-index: 999;
	}
	.sound-icon {
		font-size: 26px;
		color: #fff;
	}
	
	.logo {
		width: 100px;
		height: 100px;
		margin-top: 80px; /* 让 logo 往下一点，更好看 */
	}
	
	.title {
		font-size: 18px;
		color: #FFFFFF;
		font-weight: 600;
		text-align: center;
		margin-top: 30px;
	}
	
	.version {
		font-size: 14px;
		color: #666;
		text-align: center;
	}
	
	/* 按钮固定底部 */
	.scan-box {
		margin-top: auto;
		margin-bottom: 70px;
		width: 100%; /* 占满宽度，让按钮居中 */
		box-sizing: border-box;
		display: flex;
		flex-direction: row;
		align-items: center;
		justify-content: center;
	}
	
	.scan-btn {
		background: linear-gradient(to right, #2a78b5, #64d2cb);
		background-color: #2a78b5;
		width: 260px;
		height: 64px;
		border-radius: 10px;
		display: flex;
		flex-direction: row;
		align-items: center;
		justify-content: center;
	}
	
	.scan-btn-text {
		color: #FFFFFF;
		font-size: 18px;
		font-weight: 600;
	}
	
	.custom-box {
		width: 100%;
		margin-top: 40px;
		display: flex;
		flex-direction: column;
		align-items: center;
	}
	
	.custom-btn {
		width: 80%;
		margin-bottom: 20px;
		font-weight: 600;
	}
</style>
